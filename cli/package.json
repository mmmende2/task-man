{
  "name": "task-man",
  "version": "0.2.2",
  "description": "Personal task manager for developers who live in the terminal — TUI, LAN web app, and MCP server for Claude",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mmmende2/task-man.git"
  },
  "keywords": [
    "task-manager",
    "tui",
    "cli",
    "mcp",
    "claude",
    "productivity"
  ],
  "files": [
    "dist",
    "dist-web",
    "README.md"
  ],
  "bin": {
    "task-man": "./dist/index.js",
    "task-man-mcp": "./dist/mcp/index.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./store": "./dist/store.js",
    "./types": "./dist/types.js",
    "./config": "./dist/config.js",
    "./report": "./dist/report.js",
    "./render-html": "./dist/render-html.js",
    "./email": "./dist/email.js",
    "./sessions": "./dist/sessions.js",
    "./constants": "./dist/constants.js",
    "./refine-queue": "./dist/refine-queue.js",
    "./refine-questions": "./dist/refine-questions.js",
    "./handlers": "./dist/handlers/index.js",
    "./parse-entry": "./dist/parse-entry.js",
    "./local-date": "./dist/local-date.js",
    "./api-client": "./dist/api-client.js",
    "./store-interface": "./dist/store-interface.js",
    "./local-store": "./dist/local-store.js",
    "./remote-store": "./dist/remote-store.js",
    "./get-store": "./dist/get-store.js"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && chmod +x dist/index.js dist/mcp/index.js",
    "build:web": "cd ../web && npm run build",
    "build:all": "npm run build && npm run build:web",
    "prepublishOnly": "npm run build && npm run build:web && vitest run",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "hono": "^4.12.23",
    "ink": "^6.8.0",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.4",
    "resend": "^4.1.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
