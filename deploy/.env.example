# Copy to .env (same directory) and fill in. Never commit the real .env.

# Tunnel token — Zero Trust → Networks → Tunnels → your tunnel.
TUNNEL_TOKEN=

# Origin-side Access JWT verification (both required together).
# Team domain: Zero Trust → Settings → Custom Pages ("team domain"),
#   e.g. "myteam" or "myteam.cloudflareaccess.com".
# AUD tag: Zero Trust → Access → Applications → task-man → Overview →
#   "Application Audience (AUD) Tag".
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# ── Authorization (identity-scoped tasks) ──────────────────────────────
# Every authenticated identity sees only its own tasks. These two settings
# handle the edges of that rule.

# Who owns the pre-authorization tasks (owner: null in tasks.json). Set this
# to YOUR Access login email or your existing tasks are invisible to everyone.
TASK_MAN_DEFAULT_OWNER=

# Maps service tokens (headless MCP) to the person they act for, as
# comma-separated <token common name>=<email> pairs. The common name is the
# "Client ID" name shown at Zero Trust → Access → Service Auth → Service
# Tokens (looks like "<name>.<team>.access").
# A service token that is not mapped here gets 403 even though Access lets
# it through — set this or MCP remote mode will not work.
# Example: TASK_MAN_AGENTS=mcp.myteam.access=you@example.com
TASK_MAN_AGENTS=
